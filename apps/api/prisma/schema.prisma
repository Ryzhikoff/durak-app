// Prisma schema for Durak app.
// Phase 7A introduces game persistence (Game, GameParticipant, RatingConfig)
// and wires RatingHistory into a non-nullable Game FK.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  /// Stored lowercased. Use case-insensitive comparison via lowercasing on app layer.
  login              String   @unique
  passwordHash       String
  nickname           String   @unique
  isAdmin            Boolean  @default(false)
  mustChangePassword Boolean  @default(false)
  avatarUrl          String?
  cardBackId         String   @default("classic-1")
  randomCardBack     Boolean  @default(false)
  customCardBackUrl  String?
  /// User-chosen hand sort mode. 'power' = jokers→trumps DESC→non-trumps DESC
  /// (legacy default); 'suit' = jokers→trumps DESC→non-trumps grouped by suit
  /// ASC. Only the owning user sees the effect — server never re-sorts hands.
  handSortMode       String   @default("power")
  trueskillMu        Float    @default(25.0)
  trueskillSigma     Float    @default(8.333333)
  gamesPlayed        Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  disabledAt         DateTime?

  sessions       Session[]
  ratingHistory  RatingHistory[]
  games          GameParticipant[]
  gamesLost      Game[]            @relation("GameLoser")
  faceCardUploads FaceCardAsset[]

  @@index([disabledAt])
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  lastSeenAt DateTime @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
}

model RatingHistory {
  id            String   @id @default(cuid())
  userId        String
  /// Phase 7A.1: Restrict on User delete — we never hard-delete users (admin
  /// uses soft-delete via `disabledAt`); this guards against an accidental
  /// raw SQL DELETE wiping out game history. CASCADE on Game delete is fine:
  /// games are immutable once written.
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  muBefore      Float
  sigmaBefore   Float
  muAfter       Float
  sigmaAfter    Float
  /// Display-friendly delta (e.g. conservative rating delta).
  deltaDisplay  Float
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}

/// Placeholder for admin-editable game presets (filled in later phases).
model GameSettingsTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  /// Raw JSON config; structure decided when game module ships.
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A completed game. Phase 7A: written exactly once on `game_over`.
model Game {
  id            String   @id
  /// Snapshot of LobbySettings used to run this game.
  settingsJson  Json
  startedAt     DateTime
  finishedAt    DateTime
  durationSec   Int
  /// null = draw (all players finished in the same bout).
  loserId       String?
  totalBouts    Int
  createdAt     DateTime @default(now())

  participants  GameParticipant[]
  loser         User?    @relation("GameLoser", fields: [loserId], references: [id], onDelete: SetNull)
  ratingHistory RatingHistory[]

  @@index([finishedAt(sort: Desc)])
}

/// One row per (game, user). Captures rating snapshot + per-game metrics.
model GameParticipant {
  id                  String  @id @default(cuid())
  gameId              String
  game                Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId              String
  /// Phase 7A.1: Restrict on User delete — admin uses soft-delete via
  /// `disabledAt`; this guards against an accidental raw SQL DELETE wiping
  /// out game history. CASCADE on Game delete remains because games are
  /// immutable once written.
  user                User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  /// 1 = first to clear hand, N = durak. Ties get equal place (see metrics-collector).
  place               Int
  seatIndex           Int
  isWinner            Boolean
  isLoser             Boolean
  /// TrueSkill snapshot.
  muBefore            Float
  sigmaBefore         Float
  muAfter             Float
  sigmaAfter          Float
  deltaDisplay        Float
  /// Profile snapshot for historical display.
  nicknameSnapshot    String
  avatarUrlSnapshot   String?
  /// Per-game metrics — aggregated from the engine's domain events.
  attacksMade         Int     @default(0)
  beatsMade           Int     @default(0)
  translatesMade      Int     @default(0)
  takesAsked          Int     @default(0)
  cardsTaken          Int     @default(0)
  boutsAttacked       Int     @default(0)
  boutsDefended       Int     @default(0)
  /// Cheating-related metrics.
  cheatAttemptedTotal Int     @default(0)
  cheatCaught         Int     @default(0)
  cheatEscaped        Int     @default(0)
  noticesIssued       Int     @default(0)
  noticesCorrect      Int     @default(0)
  noticesWrong        Int     @default(0)

  @@unique([gameId, userId])
  @@index([userId, gameId])
  @@index([userId, place])
}

/// Admin-uploaded face-card art (Jack/Queen/King × 4 suits = 12 slots). When a
/// row exists for a (rank, suit) pair, every client renders the uploaded image
/// instead of the default SVG silhouette. Rows are upserted by admins via the
/// `/api/admin/face-cards` controller; deleting a row falls back to the SVG.
model FaceCardAsset {
  id           String   @id @default(cuid())
  /// 'jack' | 'queen' | 'king'
  rank         String
  /// 'spades' | 'hearts' | 'diamonds' | 'clubs'
  suit         String
  /// Relative URL served by nginx, e.g. /uploads/face-cards/jack-spades.webp?v=...
  url          String
  updatedAt    DateTime @updatedAt
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([rank, suit])
}

/// Singleton TrueSkill parameters editable from the admin UI. We use a
/// fixed primary key (`'singleton'`) so the row is upsert-able. Defaults
/// match the openskill library's PlackettLuce defaults.
model RatingConfig {
  id                String   @id @default("singleton")
  initialMu         Float    @default(25.0)
  initialSigma      Float    @default(8.333333)
  beta              Float    @default(4.166667)
  tau               Float    @default(0.083333)
  drawProbability   Float    @default(0.1)
  updatedAt         DateTime @updatedAt
  updatedById       String?
}
