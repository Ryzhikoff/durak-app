# --- Environment ---
NODE_ENV=development

# --- API ---
PORT=3000
LOG_LEVEL=debug

# --- Database (Postgres) ---
# In-cluster URL used by the API container.
DATABASE_URL=postgresql://durak:durak@postgres:5432/durak
POSTGRES_USER=durak
POSTGRES_PASSWORD=durak
POSTGRES_DB=durak

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Sessions / Cookies ---
# Symmetric secret used by the API. Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-please-32-chars-minimum
# Set to true in production behind HTTPS.
COOKIE_SECURE=false
# Optional, e.g. .durak.example.com
# COOKIE_DOMAIN=
# Session TTL — default 30 days
SESSION_TTL_SECONDS=2592000

# --- Uploads ---
UPLOADS_DIR=/data/uploads

# --- Nginx host port (host:80 by default) ---
HTTP_PORT=80
